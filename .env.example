# ─────────────────────────────────────────────
# Copy this file to .env.local and fill in values
# ─────────────────────────────────────────────

# Email Configuration (Gmail SMTP)
# To get an App Password: Google Account → Security → 2-Step Verification → App passwords
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-gmail-app-password
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false

# Razorpay Payment Gateway (optional — only needed for online payments)
# Get keys from: https://dashboard.razorpay.com/app/keys
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_YOUR_TEST_KEY
RAZORPAY_KEY_SECRET=your-razorpay-secret-key

# Site display name
NEXT_PUBLIC_SITE_NAME=Vinoth Exports

# Admin Panel Access (visit /admin to log in)
# Set a strong password — this is the ONLY credential to access the admin panel
ADMIN_PASSWORD=your-strong-admin-password
# A random secret used to sign admin sessions (generate with: openssl rand -hex 32)
ADMIN_SECRET=your-random-secret-string-here
